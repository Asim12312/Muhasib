# ── Core (required — the app will refuse to start in production without these) ─
# MongoDB connection string (Atlas free tier works fine)
MONGODB_URI=mongodb://localhost:27017/muhasib
# Secret for signing session JWTs — generate with: openssl rand -hex 32
# Must be a real random value in production — a missing/weak secret here
# is a full authentication bypass, so the app throws rather than falling
# back to a guessable default once NODE_ENV=production.
JWT_SECRET=change-me-to-a-long-random-string
# Public base URL of the REAL deployed domain (used in email links).
# No trailing slash. Get this wrong and verify/reset emails will link to
# the wrong place.
APP_URL=http://localhost:3000

# ── Email delivery (Resend) — for verification, password reset, invites ─
# Without these, emails are logged to the server console instead of sent.
RESEND_API_KEY=
EMAIL_FROM=Muhasib <noreply@yourdomain.pk>

# ── Google reCAPTCHA v2 ("I'm not a robot") ─────────────────────
# Without these, the captcha is skipped (fine for local dev).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Google Sign-In (OAuth) ──────────────────────────────────────
# Without these, the "Continue with Google" button is hidden.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── FBR / PRAL Digital Invoicing API ────────────────────────────
# Optional global fallback endpoint; can also be set per-firm in the app UI
# (Firm settings). Leave blank to use the built-in sandbox simulator.
PRAL_API_URL=
